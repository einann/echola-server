// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  
  // Profile information
  displayName String?  @map("display_name")
  username    String?  @unique
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  
  // Status and presence
  statusMessage String?  @map("status_message")
  isOnline      Boolean  @default(false) @map("is_online")
  lastSeenAt    DateTime? @map("last_seen_at")
  
  // Account management
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  devices                   Device[]
  refreshTokens             RefreshToken[]
  conversationParticipants  ConversationParticipant[]
  sentMessages              Message[]                 @relation("SentMessages")
  messageStatuses           MessageStatus[]
  messageReactions          MessageReaction[]
  createdConversations      Conversation[]            @relation("ConversationCreator")
  @@map("users")
}

model Device {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  
  // Device identification
  deviceId   String @unique @map("device_id") // Generated client-side
  deviceName String @map("device_name") // e.g., "iPhone 13", "Chrome on MacBook"
  deviceType String @map("device_type") // mobile, desktop, web
  
  // Device metadata
  userAgent     String? @map("user_agent")
  ipAddress     String? @map("ip_address")
  lastActiveAt  DateTime @default(now()) @map("last_active_at")
  
  // Push notification token
  fcmToken String? @map("fcm_token")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  
  @@index([userId])
  @@map("devices")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  deviceId  String   @map("device_id")
  
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/** */

enum ConversationType {
  DIRECT
  GROUP
}

enum DeliveryStatus  {
  SENT
  DELIVERED
  READ
}

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  
  // Group-specific fields (null for DIRECT chats)
  name        String?
  description String?
  avatarUrl   String?         @map("avatar_url")
  createdBy   String?         @map("created_by")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  participants ConversationParticipant[]
  messages     Message[]
  creator      User?                     @relation("ConversationCreator", fields: [createdBy], references: [id])
  
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  
  // Participant metadata
  role           String   @default("member") // member, admin (for groups)
  joinedAt       DateTime @default(now()) @map("joined_at")
  lastReadAt     DateTime? @map("last_read_at")
  
  // Notification settings
  isMuted        Boolean  @default(false) @map("is_muted")
  
  // Soft delete for leaving conversations
  leftAt         DateTime? @map("left_at")
  
  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  
  // Message content
  content     String?  // Text content (null for media-only messages)
  contentType String   @default("text") @map("content_type") // text, image, video, audio, document
  
  // Media attachments
  mediaUrl    String?  @map("media_url")
  thumbnailUrl String? @map("thumbnail_url")
  fileName    String?  @map("file_name")
  fileSize    Int?     @map("file_size") // in bytes
  
  // Message metadata
  replyToId   String?  @map("reply_to_id") // For threaded replies
  isEdited    Boolean  @default(false) @map("is_edited")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  
  // Relations
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User              @relation("SentMessages", fields: [senderId], references: [id])
  replyTo      Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MessageReplies")
  statuses     MessageStatus[]
  reactions    MessageReaction[]
  
  // Critical indexes for performance
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

model MessageStatus {
  id        String @id @default(uuid())
  messageId String @map("message_id")
  userId    String @map("user_id")
  
  status       DeliveryStatus @default(SENT)  // ← Changed here
  deliveredAt  DateTime?      @map("delivered_at")
  readAt       DateTime?      @map("read_at")
  
  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  
  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
  @@map("message_statuses")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  
  emoji     String   // The emoji/reaction
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  
  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}