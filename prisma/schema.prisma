generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum ConversationType {
  DIRECT
  GROUP
}

enum DeliveryStatus {
  SENT
  DELIVERED
  READ
}

enum MessageType {
  TEXT
  MEDIA
  SYSTEM
  DELETED 
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// ============================================
// USER & AUTH MODELS
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  
  // Profile information
  displayName String?  @map("display_name")
  username    String?  @unique
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  
  // Status and presence
  statusMessage String?  @map("status_message")
  isOnline      Boolean  @default(false) @map("is_online")
  lastSeenAt    DateTime? @map("last_seen_at")
  
  // Account management
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  devices                  Device[]
  refreshTokens            RefreshToken[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]                 @relation("SentMessages")
  messageStatuses          MessageStatus[]
  messageReactions         MessageReaction[]
  createdConversations     Conversation[]            @relation("ConversationCreator")

  @@map("users")
}

model Device {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  
  // Device identification
  deviceId   String @unique @map("device_id")
  deviceName String @map("device_name")
  deviceType String @map("device_type")
  
  // Device metadata
  userAgent     String? @map("user_agent")
  ipAddress     String? @map("ip_address")
  lastActiveAt  DateTime @default(now()) @map("last_active_at")
  
  // Push notification token
  fcmToken String? @map("fcm_token")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  
  @@index([userId])
  @@map("devices")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  deviceId  String   @map("device_id")
  
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ============================================
// MESSAGING MODELS
// ============================================

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  
  // Group-specific fields (null for DIRECT chats)
  name        String?
  description String?
  avatarUrl   String?  @map("avatar_url")
  createdBy   String?  @map("created_by")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  participants ConversationParticipant[]
  messages     Message[]
  creator      User?                     @relation("ConversationCreator", fields: [createdBy], references: [id])
  
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  
  // Participant metadata
  role           String    @default("member") // member, admin (for groups)
  joinedAt       DateTime  @default(now()) @map("joined_at")
  lastReadAt     DateTime? @map("last_read_at")
  
  // Notification settings
  isMuted        Boolean  @default(false) @map("is_muted")
  
  // Soft delete for leaving conversations
  leftAt         DateTime? @map("left_at")
  
  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  
  // Message type ve content
  type        MessageType @default(TEXT)
  content     String?     // Text veya caption
  
  // Reply support
  replyToId   String?  @map("reply_to_id")
  
  // Edit/Delete tracking
  isEdited    Boolean  @default(false) @map("is_edited")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  
  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  
  // Relations
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User              @relation("SentMessages", fields: [senderId], references: [id])
  replyTo      Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MessageReplies")
  statuses     MessageStatus[]
  reactions    MessageReaction[]
  attachments  MessageAttachment[]  // 👈 Yeni relation
  
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@index([type])  // Media mesajlarını filtrelemek için
  @@map("messages")
}

model MessageAttachment {
  id        String    @id @default(uuid())
  messageId String    @map("message_id")
  
  // Media identification
  mediaType MediaType @map("media_type")
  mimeType  String    @map("mime_type")  // "image/jpeg", "video/mp4"
  
  // Storage references (kritik!)
  fileKey      String  @map("file_key")       // S3/MinIO key
  bucket       String                          // Hangi bucket'ta
  url          String                          // Public/signed URL
  thumbnailKey String? @map("thumbnail_key")  // Thumbnail key (varsa)
  thumbnailUrl String? @map("thumbnail_url")
  
  // File metadata
  fileName     String? @map("file_name")      // Original filename
  fileSize     Int     @map("file_size")      // Bytes
  
  // Media-specific metadata
  width        Int?                            // Image/Video
  height       Int?                            // Image/Video
  duration     Float?                          // Video/Audio (seconds)
  
  // Processing status (opsiyonel, async processing için)
  isProcessed  Boolean @default(true) @map("is_processed")
  
  // Order (çoklu attachment için)
  order        Int     @default(0)
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
  @@index([fileKey])  // Cleanup job'ları için
  @@index([bucket, createdAt])  // Storage analytics için
  @@map("message_attachments")
}

model MessageStatus {
  id        String @id @default(uuid())
  messageId String @map("message_id")
  userId    String @map("user_id")
  
  status       DeliveryStatus @default(SENT)
  deliveredAt  DateTime?      @map("delivered_at")
  readAt       DateTime?      @map("read_at")
  
  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  
  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
  @@map("message_statuses")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  
  emoji     String   // The emoji/reaction
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  
  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}