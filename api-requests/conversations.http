@baseUrl = http://localhost:3000
@contentType = application/json
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI0NjJkNTFmZi04ZTI5LTQ4YTUtOTliOS1hMjNlZTY4MTMzMzIiLCJkZXZpY2VJZCI6ImVpbmFuLW1hY2Jvb2siLCJpYXQiOjE3Njc3MTAwNzUsImV4cCI6MTc2Nzc1MzI3NX0._5OPDYLeZJfZgdX51asobE8PKg9NFwhPdfFouEZd5HU
### Create Direct Conversation
POST {{baseUrl}}/conversations
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "type": "DIRECT",
  "participantIds": ["121b6903-c359-494a-913f-6a651952f5e7"]
}

### Create Group Conversation
POST {{baseUrl}}/conversations
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "type": "GROUP",
  "participantIds": ["462d51ff-8e29-48a5-99b9-a23ee6813332", "121b6903-c359-494a-913f-6a651952f5e7"],
  "name": "Project Team",
  "description": "Team discussion for the new project",
  "avatarUrl": "https://example.com/group-avatar.jpg"
}

### Get All My Conversations
GET {{baseUrl}}/conversations
Authorization: Bearer {{token}}

### Get All My Conversations (with pagination)
GET {{baseUrl}}/conversations?limit=20&cursor=6efc7eb5-f391-48bb-9188-185536c2a9d3
Authorization: Bearer {{token}}

### Search Conversations by name or participant
GET {{baseUrl}}/conversations?search=test
Authorization: Bearer {{token}}

### Filter Conversations by type (DIRECT or GROUP)
GET {{baseUrl}}/conversations?type=GROUP
Authorization: Bearer {{token}}

### Filter Muted Conversations
GET {{baseUrl}}/conversations?muted=true
Authorization: Bearer {{token}}

### Combined Search and Filters
GET {{baseUrl}}/conversations?search=project&type=GROUP&muted=false&limit=10
Authorization: Bearer {{token}}

### Get Conversation by ID
GET {{baseUrl}}/conversations/6efc7eb5-f391-48bb-9188-185536c2a9d3
Authorization: Bearer {{token}}

### ==================================================
### GROUP MANAGEMENT ENDPOINTS
### ==================================================

@conversationId = 6efc7eb5-f391-48bb-9188-185536c2a9d3

### Add Members to Group
POST {{baseUrl}}/conversations/{{conversationId}}/members
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "userIds": ["6645958b-b08a-42d9-b20c-9b566bfe1a96"]
}

### Remove Member from Group
DELETE {{baseUrl}}/conversations/{{conversationId}}/members/6645958b-b08a-42d9-b20c-9b566bfe1a96
Authorization: Bearer {{token}}

### Leave Group
POST {{baseUrl}}/conversations/{{conversationId}}/leave
Authorization: Bearer {{token}}

### Update Member Role
PUT {{baseUrl}}/conversations/{{conversationId}}/members/6645958b-b08a-42d9-b20c-9b566bfe1a96/role
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "role": "admin"
}

### Update Group Info
PUT {{baseUrl}}/conversations/{{conversationId}}
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "name": "Updated Project Team",
  "description": "New description for the team",
  "avatarUrl": "https://example.com/new-avatar.jpg"
}

### Get Group Members
GET {{baseUrl}}/conversations/{{conversationId}}/members
Authorization: Bearer {{token}}

### ==================================================
### CONVERSATION MANAGEMENT ENDPOINTS
### ==================================================

### Mute Conversation
POST {{baseUrl}}/conversations/{{conversationId}}/mute
Authorization: Bearer {{token}}

### Unmute Conversation
POST {{baseUrl}}/conversations/{{conversationId}}/unmute
Authorization: Bearer {{token}}

### Archive Conversation
POST {{baseUrl}}/conversations/{{conversationId}}/archive
Authorization: Bearer {{token}}

### Unarchive Conversation
POST {{baseUrl}}/conversations/{{conversationId}}/unarchive
Authorization: Bearer {{token}}

### Filter Archived Conversations
GET {{baseUrl}}/conversations?archived=true
Authorization: Bearer {{token}}

### Pin Conversation
POST {{baseUrl}}/conversations/{{conversationId}}/pin
Authorization: Bearer {{token}}

### Unpin Conversation
POST {{baseUrl}}/conversations/{{conversationId}}/unpin
Authorization: Bearer {{token}}

### Delete Conversation (Direct conversations only)
DELETE {{baseUrl}}/conversations/d7467004-35c9-48c6-a055-6986f507d770
Authorization: Bearer {{token}}
